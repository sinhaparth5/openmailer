OPENMAILER_IMAGE=ghcr.io/your-github-user/openmailer:latest
APP_BASE_URL=https://mail.example.com
APP_BIND_IP=127.0.0.1
APP_HOST_PORT=8080
DOCKER_NETWORK=openmailer-runtime

DATABASE_URL=jdbc:postgresql://postgres:5432/openmailer
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-this-postgres-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
APP_MAIL_FROM=no-reply@example.com
APP_TEST_EMAIL_RECIPIENT=

ENCRYPTION_KEY=change-this-32-char-secret-key!!
JWT_SECRET=change-this-base64-jwt-secret
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
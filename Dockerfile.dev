# Development Dockerfile for OpenMailer with JDWP enabled
# Stage 1: Build the application
FROM eclipse-temurin:25-jdk AS builder

# Install Node.js for Tailwind CSS compilation
RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files and install Node dependencies
COPY package*.json ./
RUN npm install

# Copy Maven wrapper and pom.xml
COPY mvnw* ./
COPY .mvn .mvn
COPY pom.xml ./

# Download Maven dependencies
RUN ./mvnw dependency:go-offline -B

# Copy source code
COPY src ./src
COPY tailwind.config.js ./

# Build frontend assets and application
RUN npm run build:prod
RUN ./mvnw clean package -DskipTests

# Stage 2: Development runtime image
FROM eclipse-temurin:25-jre

WORKDIR /app

COPY --from=builder /app/target/openmailer-0.0.1-SNAPSHOT.jar app.jar

EXPOSE 8080 5005

ENV SPRING_PROFILES_ACTIVE=dev
ENV JAVA_TOOL_OPTIONS="-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005"

ENTRYPOINT ["java", "-jar", "app.jar"]

SPRING_PROFILES_ACTIVE=dev

SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# Local host run:
# DATABASE_URL=jdbc:postgresql://localhost:5432/openmailer
# Docker app run:
DATABASE_URL=jdbc:postgresql://postgres:5432/openmailer
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
POSTGRES_DB=openmailer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Local host run:
# REDIS_HOST=localhost
# Docker app run:
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
CACHE_TYPE=redis

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

ENCRYPTION_KEY=change-this-32-char-secret-key!!
JWT_SECRET=change-this-jwt-secret-key-32!!
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

APP_TEST_EMAIL_RECIPIENT=
APP_ASSETS_MINIFIED=false
